# ============================================================
# IIMP Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Required: Your OpenAI API Key
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY_HERE

# Optional: Change these in production
JWT_SECRET=iimp-very-long-secret-key-minimum-256-bits-required-here-please-change
DB_USER=iimp
DB_PASS=iimp_secret
