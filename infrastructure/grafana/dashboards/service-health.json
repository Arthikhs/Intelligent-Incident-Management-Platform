{
  "title": "IIMP — Service Health",
  "uid": "iimp-service-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Service Health Scores",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "service_health_score",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "minValue": 0,
        "maxValue": 100,
        "thresholds": {
          "steps": [
            { "color": "red",    "value": 0  },
            { "color": "yellow", "value": 60 },
            { "color": "green",  "value": 85 }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate by Service",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "service_error_rate",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P99 Latency by Service (ms)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket[5m])) * 1000",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "RCA Generation Duration (ms)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rca_generation_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "RCA Success Rate",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(rca_generated_total{status=\"success\"}[5m]) / rate(rca_generated_total[5m]) * 100",
          "legendFormat": "Success %"
        }
      ]
    }
  ]
}
